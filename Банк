class Банк():
    def __init__(self, баланс_карты, баланс_кредитки, процент_кредита):
        self.баланс_карты = баланс_карты
        self.баланс_кредитки = баланс_кредитки
        self.процент_кредита = процент_кредита



    def пополнить_карту(self, пополнить):
        if пополнить > 0:
            self.баланс_карты += пополнить
            print(f"Пополнение карты {пополнить}. Баланс: {self.баланс_карты}")
        elif пополнить < 0:
            print("Пополнение должно быть больше 0")

    def снять_с_карты(self, снять):
        if снять > 0:
            if снять <= self.баланс_карты:
                self.баланс_карты -= снять
                print(f"Снятие с карты {снять}. Баланс: {self.баланс_карты}")
            elif self.баланс_карты - снять < 0:
                print("Недостаточно средств")
        elif снять <= 0:
            print("Снятие должно быть больше 0")

    def пополнить_кредитку(self, пополнить):
        if пополнить > 0:
            if self.баланс_карты >= пополнить:
                self.баланс_карты -= пополнить
                self.баланс_кредитки += пополнить
                print(f"Списано с карты {пополнить}. Баланс: {self.баланс_карты}")
                print(f"Пополнение кредитки {пополнить}. Баланс: {self.баланс_кредитки}")
            elif self.баланс_карты < 0:
                print("Недостаточно средств")
        elif пополнить <= 0:
            print("Пополнение должно быть больше 0")

    def снять_с_кредитки(self, снять):
        if снять > 0:
            if self.баланс_кредитки - снять >= 0:
                self.баланс_кредитки -= снять
                print(f"Списано с кредитки {снять}. Баланс: {self.баланс_кредитки}")
            else:
                превышение = снять - self.баланс_кредитки
                with_interest = превышение + (превышение * self.процент_кредита)
                self.баланс_кредитки = 0 - with_interest
                print(f"Списано с кредитки {снять}. Баланс: {self.баланс_кредитки}")
        elif снять <= 0:
            print("Снятие должно быть больше 0")

    def __str__(self):
        return f"Дебет: {self.баланс_карты} | Кредит: {self.баланс_кредитки}"

    def __bool__(self):
        if self.баланс_кредитки < 0:
            print("Есть долг с процентами")
            return True
        elif self.баланс_кредитки == 0:
            print("Беспроцентные деньги кончились, но долга нет")
            return False
        elif self.баланс_кредитки > 0:
            print("Ещё есть беспроцентные деньги")
            return False

мойбанк = Банк(1000, 5000,  0.1)
мойбанк.пополнить_карту(-100)
мойбанк.снять_с_карты(2000)
мойбанк.снять_с_карты(200)
мойбанк.снять_с_кредитки(1)
мойбанк.снять_с_кредитки(9999)
print(мойбанк.баланс_карты, мойбанк.баланс_кредитки)
print(bool(мойбанк))
мойбанк.пополнить_карту(16000)
мойбанк.пополнить_кредитку(10000)
print(bool(мойбанк))
